pipeline {
    agent any

    environment {
        JAVA_HOME            = "/usr/lib/jvm/java-21-openjdk-amd64"
        PATH                 = "${JAVA_HOME}/bin:${PATH}:/usr/local/bin"

        APP_NAME             = "veterian-clinic-mono"
        GIT_REPO_URL         = "https://github.com/cm-akkaya/veterian-clinic-mono"
        GIT_BRANCH           = "main"

        HARBOR_FQDN          = "172.17.160.76"
        HARBOR_PROJECT       = "ngn-list-vmware"
        IMAGE_NAME           = "spring-ngn-app"
        IMAGE_TAG            = "${BUILD_NUMBER}"          // Her build'e unique tag
        FULL_IMAGE           = "${HARBOR_FQDN}/${HARBOR_PROJECT}/${IMAGE_NAME}:${IMAGE_TAG}"

        // Jenkins Credentials'da tanımlı olmalı:
        // Kind: "Username with password"  |  ID: harbor-robot-credentials
        HARBOR_CREDENTIALS   = "harbor-robot-credentials"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))   // Son 10 build'i tut
        timestamps()                                      // Log satırlarına zaman damgası
        timeout(time: 30, unit: 'MINUTES')               // Toplam pipeline timeout
    }

    stages {

        // ------------------------------------------------------------------ //
        stage('Checkout') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Checking out branch: ${GIT_BRANCH}"
                checkout([
                    $class           : 'GitSCM',
                    branches         : [[name: "*/${GIT_BRANCH}"]],
                    userRemoteConfigs: [[url: "${GIT_REPO_URL}"]]
                ])
                sh 'echo "Workspace: ${WORKSPACE}" && ls -la'
            }
        }

        // ------------------------------------------------------------------ //
        stage('Build Docker Image') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Docker image build ediliyor: ${FULL_IMAGE}"
                sh '''
                    docker build -t ${FULL_IMAGE} .
                '''
            }
            post {
                success { echo "✅ Docker image build başarılı." }
                failure { echo "❌ Docker image build başarısız. Logları kontrol et." }
            }
        }

        // ------------------------------------------------------------------ //
        stage('Harbor Login') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Harbor'a login olunuyor: ${HARBOR_FQDN}"
                withCredentials([usernamePassword(
                    credentialsId : "${HARBOR_CREDENTIALS}",
                    usernameVariable: 'HARBOR_USER',
                    passwordVariable: 'HARBOR_PASS'
                )]) {
                    sh '''
                    echo "${HARBOR_PASS}" | docker login "${HARBOR_FQDN}" -u "${HARBOR_USER}" --password-stdin
                    '''
                }
            }
        }

        // ------------------------------------------------------------------ //
        stage('Push Image to Harbor') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> İmaj Harbor'a push ediliyor: ${FULL_IMAGE}"
                sh '''
                    docker push ${FULL_IMAGE}
                '''
            }
            post {
                success { echo "✅ İmaj Harbor'a push edildi." }
                failure { echo "❌ Harbor push başarısız." }
            }
        }

        // ------------------------------------------------------------------ //
        stage('Stop Old Containers') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Eski container'lar durduruluyor..."
                sh '''
                    cd ${WORKSPACE}
                    docker compose -f docker-compose.harbor.yml down --remove-orphans || true
                '''
            }
        }

        // ------------------------------------------------------------------ //
        stage('Deploy') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Uygulama başlatılıyor (Harbor image tag: ${IMAGE_TAG})"
                sh '''
                    cd ${WORKSPACE}
                    IMAGE_TAG=${IMAGE_TAG} \
                    HARBOR_FQDN=${HARBOR_FQDN} \
                    HARBOR_PROJECT=${HARBOR_PROJECT} \
                    docker compose -f docker-compose.harbor.yml up -d
                '''
            }
            post {
                success { echo "✅ Deploy tamamlandı." }
                failure { echo "❌ Deploy başarısız." }
            }
        }

        // ------------------------------------------------------------------ //
        stage('Health Check') {
        // ------------------------------------------------------------------ //
            steps {
                echo "==> Servisler ayağa kalkıyor, 30 saniye bekleniyor..."
                sh 'sleep 30'
                sh '''
                    cd ${WORKSPACE}
                    docker compose -f docker-compose.harbor.yml ps
                '''
                echo "==> Uygulama erişim kontrolü:"
                sh '''
                    curl -sf http://${HARBOR_FQDN}:8081/actuator/health \
                        && echo "✅ Uygulama sağlıklı" \
                        || echo "⚠️  Uygulama henüz hazır olmayabilir, container loglarını kontrol et"
                '''
            }
        }

    } // end stages

    post {
        success {
            echo """
            ✅ Pipeline başarıyla tamamlandı!
            ─────────────────────────────────────────
            Build     : #${BUILD_NUMBER}
            Image     : ${FULL_IMAGE}
            App URL   : http://${HARBOR_FQDN}:8081
            Harbor    : https://${HARBOR_FQDN}/harbor/projects
            ─────────────────────────────────────────
            """
        }
        failure {
            echo "❌ Pipeline başarısız! Build #${BUILD_NUMBER} — Jenkins loglarını incele."
        }
        always {
            echo "==> Dangling (sahipsiz) imajlar temizleniyor..."
            sh 'docker image prune -f'   // -a YOK: sadece dangling sil, build cache kalsın
            sh 'docker logout ${HARBOR_FQDN} || true'
        }
    }
}
